# api-football via RapidAPI — https://rapidapi.com/api-sports/api/api-football
# Free tier: 100 req/day. Paid Basic (~$6/mo): 7,500 req/day — required for live polling.
RAPIDAPI_KEY=

# Anthropic Claude API — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Web Push (VAPID) — generate with: npm run vapid
# IMPORTANT: the public key is also used by the browser service worker.
# Once set in production, never rotate without re-subscribing all users.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# PostgreSQL connection string
# Local:   postgres://user:password@localhost:5432/kickoffai
# Railway: set automatically when you add the Postgres plugin -- do not set manually.
DATABASE_URL=postgres://localhost:5432/kickoffai

# Google Places API — https://console.cloud.google.com (Places API must be enabled)
GOOGLE_PLACES_API_KEY=

# Server
# Railway sets PORT automatically -- do not override in Railway env vars.
PORT=3001
# Set to "production" in Railway environment variables.
NODE_ENV=development
