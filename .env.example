# api-football direct API key -- dashboard.api-football.com
# Free tier: 100 req/day. Basic plan (~$4/mo): 7,500 req/day.
API_SPORTS_KEY=

# Anthropic Claude API -- console.anthropic.com
ANTHROPIC_API_KEY=

# Google Places API -- console.cloud.google.com (Places API must be enabled)
GOOGLE_PLACES_API_KEY=

# Server (Railway sets PORT automatically -- do not override in Railway env vars)
PORT=3001
NODE_ENV=development
